<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flash Card - Verdadeiro ou Falso</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #74ebd5 0%, #9face6 100%);
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        /* Cabeçalho com o nome */
        .header-msg {
            background-color: white;
            padding: 10px 20px;
            border-radius: 20px;
            margin-bottom: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            font-size: 1.1rem;
            font-weight: bold;
            color: #333;
            text-align: center;
        }

        /* Estrutura do Flash Card */
        .flashcard-container {
            perspective: 1000px;
            width: 350px;
            height: 280px; /* Aumentado levemente para caber os textos maiores */
            margin-bottom: auto;
        }

        .card {
            width: 100%;
            height: 100%;
            transition: transform 0.6s ease;
            transform-style: preserve-3d;
            cursor: pointer;
            position: relative;
        }

        .card.is-flipped {
            transform: rotateY(180deg);
        }

        .card-front, .card-back {
            backface-visibility: hidden;
            width: 100%;
            height: 100%;
            position: absolute;
            border-radius: 20px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .card-front {
            background-color: #ffffff;
        }

        .card-back {
            background-color: #2c3e50;
            color: white;
            transform: rotateY(180deg);
        }

        .question {
            font-size: 1.2rem;
            text-align: center;
            margin-bottom: 20px;
            font-weight: 500;
            line-height: 1.4;
        }

        .instruction {
            font-size: 0.85rem;
            color: #777;
            margin-top: 15px;
        }

        /* Botões de V ou F */
        .btn-container {
            display: flex;
            gap: 20px;
        }

        .btn {
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-true {
            background-color: #2ecc71;
            color: white;
        }

        .btn-true:hover {
            background-color: #27ae60;
        }

        .btn-false {
            background-color: #e74c3c;
            color: white;
        }

        .btn-false:hover {
            background-color: #c0392b;
        }

        .result {
            font-size: 1.2rem;
            font-weight: bold;
            text-align: center;
            margin-bottom: 20px;
            line-height: 1.4;
        }

        .btn-next {
            padding: 10px 20px;
            background-color: #3498db;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
        }

        .btn-next:hover {
            background-color: #2980b9;
        }

        /* Rodapé */
        footer {
            margin-top: auto;
            padding: 15px;
            width: 100%;
            text-align: center;
            background-color: #222;
            color: white;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <!-- Mensagem flutuante de boas-vindas -->
    <div id="mensagemBoasVindas" class="header-msg">
        Site criado por Gustavo de Moura do 2º B
    </div>

    <!-- Flash Card -->
    <div class="flashcard-container">
        <div class="card" id="meuCard" onclick="virarCard()">
            <!-- Lado da Pergunta -->
            <div class="card-front">
                <div class="question" id="perguntaTexto">
                    Carregar pergunta...
                </div>
                <div class="btn-container">
                    <button class="btn btn-true" onclick="verificarResposta(true, event)">Verdadeiro</button>
                    <button class="btn btn-false" onclick="verificarResposta(false, event)">Falso</button>
                </div>
                <div class="instruction">Clique no card se quiser ver a resposta direto</div>
            </div>
            
            <!-- Lado da Resposta -->
            <div class="card-back">
                <div class="result" id="resultadoTexto">Resultado</div>
                <button class="btn-next" onclick="proximaPergunta(event)">Próxima Pergunta</button>
            </div>
        </div>
    </div>

    <!-- Rodapé -->
    <footer>
        Desenvolvido com dedicação por Gustavo de Moura - 2º B
    </footer>

    <script>
        // Banco de dados com 3 verdadeiras e 3 falsas alternadas
        const perguntas = [
            // --- VERDADEIRAS ---
            { 
                texto: "A Lua é o único satélite natural da Terra?", 
                resposta: true, 
                explicacao: "Verdadeiro! Ela orbita nosso planeta há bilhões de anos." 
            },
            { 
                texto: "A água ferve a 100°C ao nível do mar?", 
                resposta: true, 
                explicacao: "Verdadeiro! Essa é a temperatura padrão de ebulição da água nessa altitude." 
            },
            { 
                texto: "O oxigênio é o elemento essencial para a nossa respiração?", 
                resposta: true, 
                explicacao: "Verdadeiro! Nossas células precisam dele para produzir energia." 
            },
            
            // --- FALSAS ---
            { 
                texto: "O Sol gira ao redor da Terra?", 
                resposta: false, 
                explicacao: "Falso! É a Terra (e outros planetas) que gira ao redor do Sol." 
            },
            { 
                texto: "Os humanos têm três pulmões no corpo?", 
                resposta: false, 
                explicacao: "Falso! Nós temos apenas dois pulmões (o esquerdo e o direito)." 
            },
            { 
                texto: "O Brasil é o maior país do mundo em território?", 
                resposta: false, 
                explicacao: "Falso! O maior país do mundo em extensão territorial é a Rússia." 
            }
        ];

        let perguntaAtual = 0;

        // Inicia a primeira pergunta ao abrir a página
        window.onload = function() {
            carregarPergunta();
        };

        function carregarPergunta() {
            document.getElementById("perguntaTexto").innerText = perguntas[perguntaAtual].texto;
        }

        function virarCard() {
            const card = document.getElementById("meuCard");
            card.classList.toggle("is-flipped");
        }

        function verificarResposta(escolha, event) {
            event.stopPropagation(); // Impede o clique de virar o card duas vezes

            const correta = perguntas[perguntaAtual].resposta;
            const resultadoTexto = document.getElementById("resultadoTexto");

            if (escolha === correta) {
                resultadoTexto.innerHTML = "<span style='color: #2ecc71;'>Correto!</span><br><br>" + perguntas[perguntaAtual].explicacao;
            } else {
                resultadoTexto.innerHTML = "<span style='color: #e74c3c;'>Incorreto!</span><br><br>" + perguntas[perguntaAtual].explicacao;
            }

            const card = document.getElementById("meuCard");
            card.classList.add("is-flipped");
        }

        function proximaPergunta(event) {
            event.stopPropagation(); 
            
            perguntaAtual++;
            if (perguntaAtual >= perguntas.length) {
                perguntaAtual = 0; // Reinicia a lista quando chega ao fim
            }

            const card = document.getElementById("meuCard");
            card.classList.remove("is-flipped");

            setTimeout(carregarPergunta, 300);
        }
    </script>
</body>
</html>
