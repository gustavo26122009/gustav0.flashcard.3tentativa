<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flashcards Verdadeiro ou Falso</title>
    <style>
        /* Configurações Globais */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #182b46;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            gap: 20px;
            padding: 20px;
            box-sizing: border-box;
        }

        /* Container do Carrossel */
        .quiz-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
        }

        /* Container do Flashcard */
        .flashcard {
            background-color: transparent;
            width: 320px;
            height: 240px;
            perspective: 1000px; /* Cria o efeito 3D */
            cursor: pointer;
            display: none; /* Esconde todos por padrão */
        }

        /* Classe ativa para mostrar apenas o card atual */
        .flashcard.active {
            display: block;
        }

        /* Elemento interno que vai girar */
        .flashcard-inner {
            position: relative;
            width: 100%;
            height: 100%;
            text-align: center;
            transition: transform 0.6s;
            transform-style: preserve-3d;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            border-radius: 10px;
        }

        /* Efeito de giro ao passar o mouse */
        .flashcard:hover .flashcard-inner {
            transform: rotateY(180deg);
        }

        /* Estilo comum para a Frente e o Verso */
        .flashcard-front, .flashcard-back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden; /* Esconde o lado oposto */
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border-radius: 10px;
            padding: 24px;
            box-sizing: border-box;
        }

        /* Estilo da Frente */
        .flashcard-front {
            background-color: #ffffff;
            color: #333333;
            border: 2px solid #007bff;
        }

        .flashcard-front span {
            font-size: 12px;
            color: #007bff;
            text-transform: uppercase;
            font-weight: bold;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .flashcard-front h2 {
            margin: 0;
            font-size: 18px;
            line-height: 1.5;
            font-weight: 600;
        }

        /* Estilo do Verso */
        .flashcard-back {
            background-color: #007bff;
            color: white;
            transform: rotateY(180deg); /* Começa virado */
        }

        .flashcard-back p {
            font-size: 26px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0;
        }

        /* Controles de Navegação */
        .controls {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .btn {
            background-color: #007bff;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 5px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn:hover {
            background-color: #0056b3;
        }

        .btn:disabled {
            background-color: #4a5a70;
            cursor: not-allowed;
        }

        .counter {
            color: white;
            font-size: 16px;
            font-weight: bold;
        }
    </style>
</head>
